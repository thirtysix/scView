# scView Configuration

# Data directory (inside Docker containers)
DATA_DIR=/data

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=2048

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# DeepInfra API key (optional - for LLM-powered analysis suggestions)
# Get one at https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=

# R Converter service URL (internal Docker network)
CONVERTER_URL=http://converter:8001

# MSigDB gene set files directory (host path, mounted read-only into container)
# Download from https://www.gsea-msigdb.org/gsea/msigdb/
MSIGDB_HOST_DIR=

# --- RAG co-pilot (literature + tutorials corpora over pgvector) -------------
# Postgres/Neon connection string with the pgvector extension. Empty disables
# RAG retrieval (the co-pilot still grounds answers in the dataset's own facts).
# Reuse a WntHub-style Neon instance or a fresh DB; vectors are namespaced by a
# `corpus` column so they won't collide with other apps' tables.
RAG_DATABASE_URL=
# DeepInfra models (defaults match the WntHub corpus pipeline).
RAG_EMBED_MODEL=BAAI/bge-base-en-v1.5
RAG_CHAT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
